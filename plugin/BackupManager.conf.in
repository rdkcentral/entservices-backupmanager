precondition = ["Platform"]
callsign = "org.rdk.BackupManager"
autostart = "false"
startuporder = "@PLUGIN_BACKUPMANAGER_STARTUPORDER@"

configuration = JSON()
rootobject = JSON()

rootobject.add("mode", "@PLUGIN_BACKUPMANAGER_MODE@")
rootobject.add("locator", "lib@PLUGIN_IMPLEMENTATION@.so")

configuration.add("root", rootobject)
